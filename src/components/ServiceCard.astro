---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string; // SVG path data or emoji fallback
}

const { title, description, href, icon } = Astro.props;
---

<article class="group bg-cream border border-cream-dark hover:border-gold/40 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 flex flex-col">
  <!-- Top accent bar -->
  <div class="h-1 bg-hunter group-hover:bg-gold transition-colors duration-300"></div>

  <div class="p-8 flex flex-col flex-1">
    <!-- Icon -->
    <div class="w-12 h-12 flex items-center justify-center border border-hunter/20 group-hover:border-gold group-hover:bg-gold/10 transition-all duration-300 mb-6">
      {icon ? (
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-hunter group-hover:text-gold transition-colors duration-300">
          <path d={icon} />
        </svg>
      ) : (
        <span class="text-gold text-lg">✦</span>
      )}
    </div>

    <!-- Content -->
    <h3 class="font-serif text-hunter text-xl font-bold mb-3">{title}</h3>
    <p class="font-sans text-charcoal/70 text-sm leading-relaxed flex-1">{description}</p>

    <!-- Link -->
    <a
      href={href}
      class="inline-flex items-center gap-2 font-sans text-xs font-semibold uppercase tracking-widest text-hunter group-hover:text-gold transition-colors duration-200 mt-6 border-t border-cream-dark pt-4"
    >
      Learn More
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</article>
