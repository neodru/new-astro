---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/boarding", label: "Boarding" },
  { href: "/training", label: "Training" },
  { href: "/lessons", label: "Lessons" },
  { href: "/events", label: "Events" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 bg-hunter/95 backdrop-blur-sm border-b border-gold/20">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <span class="text-gold text-2xl">✦</span>
        <div class="flex flex-col leading-none">
          <span class="font-serif text-cream text-lg font-bold tracking-wide">Poway Equestrian</span>
          <span class="font-sans text-gold text-xs font-medium uppercase tracking-[0.15em]">Center</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="font-sans text-sm font-medium text-cream/80 hover:text-gold transition-colors duration-200 uppercase tracking-wider"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA Button -->
      <div class="hidden lg:block">
        <a
          href="/contact"
          class="font-sans text-sm font-semibold uppercase tracking-widest px-6 py-2.5 border border-gold text-gold hover:bg-gold hover:text-hunter transition-all duration-200"
        >
          Book a Tour
        </a>
      </div>

      <!-- Mobile hamburger -->
      <label class="lg:hidden cursor-pointer" for="mobile-menu-toggle">
        <div class="flex flex-col gap-1.5 p-2">
          <span class="block w-6 h-0.5 bg-cream transition-all duration-300"></span>
          <span class="block w-6 h-0.5 bg-cream transition-all duration-300"></span>
          <span class="block w-4 h-0.5 bg-cream transition-all duration-300"></span>
        </div>
      </label>
    </div>
  </div>

  <!-- Mobile Menu (CSS-only toggle) -->
  <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
  <div class="hidden peer-checked:block lg:hidden bg-hunter border-t border-gold/20">
    <nav class="flex flex-col px-6 py-4 gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-sans text-sm font-medium text-cream/80 hover:text-gold py-3 border-b border-cream/10 uppercase tracking-wider transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contact"
        class="mt-4 font-sans text-sm font-semibold uppercase tracking-widest px-6 py-3 border border-gold text-gold hover:bg-gold hover:text-hunter transition-all duration-200 text-center"
      >
        Book a Tour
      </a>
    </nav>
  </div>
</header>
