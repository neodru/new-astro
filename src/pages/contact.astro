---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact Us | Poway Equestrian Center"
  description="Contact Poway Equestrian Center. Call 858-748-6441 or email ride@powayequestriancenter.com. Located at 14875 Mina de Oro Rd, Poway, CA 92064."
>
  <!-- Page header -->
  <section class="relative py-32 px-6 bg-hunter overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-gold to-transparent"></div>
    <div class="max-w-4xl mx-auto text-center">
      <p class="font-sans text-gold text-xs font-semibold uppercase tracking-[0.3em] mb-4">We'd Love to Hear From You</p>
      <h1 class="font-serif text-cream text-5xl sm:text-6xl font-bold leading-tight mb-6">
        Get in Touch
      </h1>
      <div class="w-16 h-0.5 bg-gold mx-auto mb-8"></div>
      <p class="font-sans text-cream/70 text-lg leading-relaxed max-w-2xl mx-auto">
        Whether you're ready to book a lesson, inquire about boarding, plan an event, or simply want to visit — we're here to help.
      </p>
    </div>
  </section>

  <!-- Contact info + form -->
  <section class="py-24 px-6 bg-cream">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16">

      <!-- Contact Details -->
      <div>
        <p class="font-sans text-gold text-xs font-semibold uppercase tracking-[0.3em] mb-6">Contact Information</p>

        <div class="space-y-8">
          <div class="flex gap-5">
            <div class="w-10 h-10 border border-hunter/20 flex items-center justify-center shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gold">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="font-sans text-xs font-semibold uppercase tracking-widest text-charcoal/40 mb-1">Address</p>
              <p class="font-sans text-charcoal text-base">14875 Mina de Oro Rd</p>
              <p class="font-sans text-charcoal text-base">Poway, CA 92064</p>
              <a
                href="https://maps.google.com/?q=14875+Mina+de+Oro+Rd+Poway+CA+92064"
                target="_blank"
                rel="noopener noreferrer"
                class="font-sans text-xs text-gold hover:underline mt-1 inline-block"
              >
                Get Directions →
              </a>
            </div>
          </div>

          <div class="flex gap-5">
            <div class="w-10 h-10 border border-hunter/20 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gold">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.49 12 19.79 19.79 0 0 1 1.42 3.18 2 2 0 0 1 3.4 1h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.4a16 16 0 0 0 5.69 5.69l.76-.76a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21 16.92z"/>
              </svg>
            </div>
            <div>
              <p class="font-sans text-xs font-semibold uppercase tracking-widest text-charcoal/40 mb-1">Phone</p>
              <a href="tel:8587486441" class="font-sans text-charcoal text-base hover:text-gold transition-colors">
                858-748-6441
              </a>
            </div>
          </div>

          <div class="flex gap-5">
            <div class="w-10 h-10 border border-hunter/20 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gold">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <div>
              <p class="font-sans text-xs font-semibold uppercase tracking-widest text-charcoal/40 mb-1">Email</p>
              <a href="mailto:ride@powayequestriancenter.com" class="font-sans text-charcoal text-base hover:text-gold transition-colors break-all">
                ride@powayequestriancenter.com
              </a>
            </div>
          </div>
        </div>

        <!-- Hours table -->
        <div class="mt-12">
          <p class="font-sans text-xs font-semibold uppercase tracking-widest text-charcoal/40 mb-4">Office Hours</p>
          <table class="w-full font-sans text-sm">
            <tbody class="divide-y divide-cream-dark">
              <tr>
                <td class="py-3 text-charcoal/70">Monday – Friday</td>
                <td class="py-3 text-right text-hunter font-medium">9:00 am – 5:00 pm</td>
              </tr>
              <tr>
                <td class="py-3 text-charcoal/70">Saturday – Sunday</td>
                <td class="py-3 text-right text-hunter font-medium">9:00 am – 4:00 pm</td>
              </tr>
              <tr>
                <td class="py-3 text-charcoal/70">Boarding Emergencies</td>
                <td class="py-3 text-right text-gold font-medium">24 / 7</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Map placeholder -->
        <div class="mt-12">
          {/* DALL-E Prompt: A clean, simple illustrated map pin icon on a soft cream background
              showing the location of Poway, CA. Not needed — use Google Maps embed. */}
          <div class="w-full aspect-video bg-cream-dark border border-cream-dark flex items-center justify-center">
            <div class="text-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gold mx-auto mb-3">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <p class="font-sans text-sm text-charcoal/50">14875 Mina de Oro Rd, Poway CA</p>
              <a
                href="https://maps.google.com/?q=14875+Mina+de+Oro+Rd+Poway+CA+92064"
                target="_blank"
                rel="noopener noreferrer"
                class="font-sans text-xs text-gold hover:underline mt-1 inline-block"
              >
                Open in Google Maps →
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <p class="font-sans text-gold text-xs font-semibold uppercase tracking-[0.3em] mb-6">Send a Message</p>
        <form
          name="contact"
          method="POST"
          action="/contact"
          class="space-y-6"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="first-name" class="block font-sans text-xs font-semibold uppercase tracking-widest text-charcoal/50 mb-2">
                First Name <span class="text-gold">*</span>
              </label>
              <input
                type="text"
                id="first-name"
                name="first-name"
                required
                class="w-full border border-cream-dark bg-cream px-4 py-3 font-sans text-sm text-charcoal placeholder-charcoal/30 focus:outline-none focus:border-gold transition-colors duration-200"
                placeholder="Jane"
              />
            </div>
            <div>
              <label for="last-name" class="block font-sans text-xs font-semibold uppercase tracking-widest text-charcoal/50 mb-2">
                Last Name <span class="text-gold">*</span>
              </label>
              <input
                type="text"
                id="last-name"
                name="last-name"
                required
                class="w-full border border-cream-dark bg-cream px-4 py-3 font-sans text-sm text-charcoal placeholder-charcoal/30 focus:outline-none focus:border-gold transition-colors duration-200"
                placeholder="Smith"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block font-sans text-xs font-semibold uppercase tracking-widest text-charcoal/50 mb-2">
              Email Address <span class="text-gold">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full border border-cream-dark bg-cream px-4 py-3 font-sans text-sm text-charcoal placeholder-charcoal/30 focus:outline-none focus:border-gold transition-colors duration-200"
              placeholder="jane@example.com"
            />
          </div>

          <div>
            <label for="phone" class="block font-sans text-xs font-semibold uppercase tracking-widest text-charcoal/50 mb-2">
              Phone Number
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full border border-cream-dark bg-cream px-4 py-3 font-sans text-sm text-charcoal placeholder-charcoal/30 focus:outline-none focus:border-gold transition-colors duration-200"
              placeholder="(858) 555-0100"
            />
          </div>

          <div>
            <label for="interest" class="block font-sans text-xs font-semibold uppercase tracking-widest text-charcoal/50 mb-2">
              I'm Interested In <span class="text-gold">*</span>
            </label>
            <select
              id="interest"
              name="interest"
              required
              class="w-full border border-cream-dark bg-cream px-4 py-3 font-sans text-sm text-charcoal focus:outline-none focus:border-gold transition-colors duration-200"
            >
              <option value="">Select an option</option>
              <option value="boarding">Horse Boarding</option>
              <option value="lessons">Riding Lessons</option>
              <option value="training">Professional Training</option>
              <option value="trail">Trail Riding</option>
              <option value="events">Event / Venue Rental</option>
              <option value="tour">Facility Tour</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block font-sans text-xs font-semibold uppercase tracking-widest text-charcoal/50 mb-2">
              Message <span class="text-gold">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full border border-cream-dark bg-cream px-4 py-3 font-sans text-sm text-charcoal placeholder-charcoal/30 focus:outline-none focus:border-gold transition-colors duration-200 resize-none"
              placeholder="Tell us how we can help..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full font-sans text-sm font-semibold uppercase tracking-widest px-8 py-4 bg-hunter text-cream hover:bg-hunter-light transition-all duration-200"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
