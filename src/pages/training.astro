---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import CTABanner from "../components/CTABanner.astro";
import { getTrainers } from "../lib/storyblok.js";

// Fetch live trainers from Storyblok; falls back to [] when token is absent.
const sbTrainers = await getTrainers();

// Static fallback shown when no Storyblok content exists yet.
const fallbackTrainers = [
  {
    full_name: "Nicole Stone",
    title: "Founder & Head Trainer",
    bio: "A San Diego native and lifelong rider, Nicole champions education above all else. Her patient, principle-based approach has helped hundreds of horse-and-rider pairs reach their full potential.",
    disciplines: ["Hunter/Jumper", "Groundwork", "Youth Development"],
    years_experience: 20,
    headshot: { filename: "/images/nicole-stone.jpg", alt: "Nicole Stone, Head Trainer" },
  },
];

// Normalize Storyblok stories to the same shape as the fallback.
const trainers = sbTrainers.length > 0
  ? sbTrainers.map((s) => s.content)
  : fallbackTrainers;

const disciplines = [
  { name: "Hunter/Jumper", desc: "Technical jumping courses, equitation, and ring craft for the show pen." },
  { name: "Western Pleasure", desc: "Smooth gaits, light hands, and the quiet communication of Western riding." },
  { name: "Trail & Endurance", desc: "Building horse and rider fitness for the open trail and long-distance riding." },
  { name: "Groundwork & Horsemanship", desc: "Foundational trust and communication between horse and handler." },
  { name: "Dressage Fundamentals", desc: "Precision, balance, and harmony — the ballet of equestrian sport." },
  { name: "Youth Development", desc: "Age-appropriate programs that build lifelong horsemanship skills and confidence." },
];
---

<Layout
  title="Horse Training | Poway Equestrian Center"
  description="Professional horse and rider training across all disciplines at Poway Equestrian Center. Elevate your skills with our experienced trainers. Call 858-748-6441."
>
  <Hero
    headline={"Elevate Your\nEquestrian Skills"}
    subheadline="Our professional trainers bring expertise across every discipline, developing the bond between horse and rider to its fullest potential."
    primaryBtnText="Book a Consultation"
    primaryBtnHref="/contact"
    secondaryBtnText="View Lessons"
    secondaryBtnHref="/lessons"
    minHeight="70vh"
  />

  <!-- Disciplines -->
  <section class="py-24 px-6 bg-cream">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <p class="font-sans text-gold text-xs font-semibold uppercase tracking-[0.3em] mb-3">Specializations</p>
        <h2 class="font-serif text-hunter text-4xl sm:text-5xl font-bold mb-4">Training Disciplines</h2>
        <div class="w-16 h-0.5 bg-gold mx-auto"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {disciplines.map((d) => (
          <div class="group p-8 border border-cream-dark hover:border-gold/40 hover:shadow-lg bg-cream transition-all duration-300">
            <div class="w-8 h-0.5 bg-gold mb-5 group-hover:w-16 transition-all duration-300"></div>
            <h3 class="font-serif text-hunter text-lg font-bold mb-3">{d.name}</h3>
            <p class="font-sans text-charcoal/70 text-sm leading-relaxed">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trainer Cards (live from Storyblok, falls back to static data) -->
  <section class="py-24 px-6 bg-hunter">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <p class="font-sans text-gold text-xs font-semibold uppercase tracking-[0.3em] mb-3">The People Behind the Program</p>
        <h2 class="font-serif text-cream text-4xl sm:text-5xl font-bold mb-4">Meet Our Trainers</h2>
        <div class="w-16 h-0.5 bg-gold mx-auto"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {trainers.map((trainer) => (
          <article class="group bg-cream/5 border border-cream/10 hover:border-gold/30 transition-all duration-300 flex flex-col">
            {/* DALL-E Prompt: Professional equestrian trainer headshot, warm stable or arena
                background, editorial portrait lighting, confident and approachable expression,
                riding attire (show jacket or polo), shallow depth of field, 4:5 portrait. */}
            <div class="aspect-4/5 overflow-hidden">
              <img
                src={trainer.headshot?.filename ?? "/images/trainer-placeholder.jpg"}
                alt={trainer.headshot?.alt ?? trainer.full_name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <div class="p-6 flex flex-col flex-1">
              <h3 class="font-serif text-cream text-xl font-bold">{trainer.full_name}</h3>
              <p class="font-sans text-gold text-xs font-semibold uppercase tracking-widest mt-1 mb-4">{trainer.title}</p>
              <p class="font-sans text-cream/60 text-sm leading-relaxed flex-1">{trainer.bio}</p>
              {trainer.disciplines?.length > 0 && (
                <div class="mt-5 pt-4 border-t border-cream/10 flex flex-wrap gap-2">
                  {trainer.disciplines.map((d) => (
                    <span class="font-sans text-xs text-gold/80 border border-gold/30 px-2 py-0.5">{d}</span>
                  ))}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="py-24 px-6 bg-cream-dark">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="relative">
        {/* DALL-E Prompt: A professional equestrian trainer in a navy show jacket working calmly
            with a dark bay horse in a pristine sand arena at golden hour. The horse is in a collected
            trot, the trainer walks alongside with a dressage whip held lightly at their side.
            Editorial photography, 4:3, warm California tones, shallow depth of field. */}
        <img
          src="/images/training-session.jpg"
          alt="Professional trainer working a dark bay horse in collected trot in the sand arena at Poway"
          class="w-full aspect-4/3 object-cover"
        />
        <div class="absolute -bottom-4 -left-4 w-full h-full border border-gold/30 -z-10"></div>
      </div>
      <div>
        <p class="font-sans text-gold text-xs font-semibold uppercase tracking-[0.3em] mb-4">Our Approach</p>
        <h2 class="font-serif text-hunter text-4xl font-bold leading-tight mb-6">
          Training Built on<br />Trust & Education
        </h2>
        <div class="w-16 h-0.5 bg-gold mb-8"></div>
        <p class="font-sans text-charcoal/70 text-base leading-relaxed mb-6">
          Under the leadership of Nicole Stone, our training philosophy centers on education, patience, and respect for the horse. We believe the best results come from building a genuine partnership rather than forcing compliance.
        </p>
        <p class="font-sans text-charcoal/70 text-base leading-relaxed mb-8">
          Every training program begins with a consultation to assess your horse's current level, your goals, and the ideal training path forward. We set measurable milestones and celebrate every step of progress.
        </p>
        <a
          href="/contact"
          class="inline-block font-sans text-sm font-semibold uppercase tracking-widest px-8 py-3 bg-hunter text-cream hover:bg-hunter-light transition-all duration-200"
        >
          Schedule a Consultation
        </a>
      </div>
    </div>
  </section>

  <CTABanner
    headline="Start Your Training Journey"
    subtext="Contact our team to discuss your goals and find the right training program for you and your horse."
    btnText="Get in Touch"
    href="/contact"
    variant="saddle"
  />
</Layout>
